# musik-in-schaumburg.de – Apache configuration

# ── JSON-LD content type and content negotiation ───────────────────────────────
AddType application/ld+json .json

# Serve .json sidecar when client accepts application/ld+json
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP:Accept} application/ld\+json
  RewriteRule ^(.+)\.html$ $1.json [T=application/ld+json,END]
</IfModule>

# ── Encoding ──────────────────────────────────────────────────────────────────
AddDefaultCharset UTF-8

# ── Rewrite engine (required for all RewriteRule directives below) ─────────────
RewriteEngine On

# ── HTTPS redirect ────────────────────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── Canonical host: redirect www → non-www ────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ── Canonical redirect: /index.html → / ──────────────────────────────────────
# Trailing-slash URLs are the canonical form (e.g. /ensemble/slug/ not
# /ensemble/slug/index.html).  Apache's mod_dir may externally redirect a
# bare directory request to its index.html file; these rules ensure that any
# explicit /index.html request — at the root or in any subdirectory — is
# permanently redirected back to the canonical trailing-slash URL.
#
# Why trailing-slash (not /index.html)?
#   • All internal links, the sitemap, and <link rel="canonical"> already use
#     the trailing-slash form, so this redirect simply enforces what the site
#     already declares as canonical.
#   • Trailing-slash URLs are cleaner and more robust: they do not expose the
#     server's file layout and remain valid if the implementation ever changes
#     from index.html to another default document.
RewriteCond %{THE_REQUEST} /index\.html[\ ?] [NC]
RewriteRule ^(.+/)?index\.html$ /$1 [R=301,L]

# ── Pre-compressed asset serving ──────────────────────────────────────────────
# Priority: zstd > brotli > gzip.
# Each rule checks that (a) the client advertises support and
# (b) the pre-compressed file actually exists on disk.
# On-the-fly fallback via mod_deflate / mod_brotli follows below.

# Skip processing if requesting compressed files directly (prevent redirect loops)
RewriteCond %{REQUEST_URI} \.(zst|br|gz)$ [NC]
RewriteRule ^ - [L]

# zstd
RewriteCond %{HTTP:Accept-Encoding} \bzstd\b
RewriteCond %{REQUEST_FILENAME}.zst -f
RewriteRule ^ %{REQUEST_URI}.zst [L]

# brotli
RewriteCond %{HTTP:Accept-Encoding} \bbr\b
RewriteCond %{REQUEST_FILENAME}.br -f
RewriteRule ^ %{REQUEST_URI}.br [L]

# gzip
RewriteCond %{HTTP:Accept-Encoding} \bgzip\b
RewriteCond %{REQUEST_FILENAME}.gz -f
RewriteRule ^ %{REQUEST_URI}.gz [L]

# ── Content-Encoding headers for pre-compressed files ────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.zst$">
    Header set Content-Encoding zstd
    Header append Vary Accept-Encoding
  </FilesMatch>
  <FilesMatch "\.br$">
    Header set Content-Encoding br
    Header append Vary Accept-Encoding
  </FilesMatch>
  <FilesMatch "\.gz$">
    Header set Content-Encoding gzip
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>

# Prevent on-the-fly compression modules from re-compressing pre-compressed files
<IfModule mod_setenvif.c>
  SetEnvIfNoCase Request_URI "\.(?:zst|br|gz)$" no-gzip=1
  SetEnvIfNoCase Request_URI "\.(?:zst|br|gz)$" no-brotli=1
</IfModule>

# ── MIME types for pre-compressed files ───────────────────────────────────────
# Apache must return the original MIME type, not the compression type.
<FilesMatch "\.html\.(zst|br|gz)$">
  ForceType text/html
</FilesMatch>
<FilesMatch "\.css\.(zst|br|gz)$">
  ForceType text/css
</FilesMatch>
<FilesMatch "\.js\.(zst|br|gz)$">
  ForceType application/javascript
</FilesMatch>
<FilesMatch "\.xml\.(zst|br|gz)$">
  ForceType application/xml
</FilesMatch>
<FilesMatch "\.txt\.(zst|br|gz)$">
  ForceType text/plain
</FilesMatch>
<FilesMatch "\.svg\.(zst|br|gz)$">
  ForceType image/svg+xml
</FilesMatch>
<FilesMatch "\.json\.(zst|br|gz)$">
  ForceType application/ld+json
</FilesMatch>

# ── On-the-fly compression fallback ───────────────────────────────────────────
# Only applies when no pre-compressed file was matched above.
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS \
    text/html text/css application/javascript \
    application/xml text/xml text/plain image/svg+xml \
    application/ld+json
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE \
    text/html text/css application/javascript \
    application/xml text/xml text/plain image/svg+xml \
    application/ld+json
</IfModule>

# ── Caching ───────────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML – short TTL so updates reach users quickly
  ExpiresByType text/html                  "access plus 1 hour"

  # CSS and JS – fingerprint in filename assumed; long TTL is safe
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"

  # Images
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fonts
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType font/woff                  "access plus 1 year"

  # Sitemap and robots.txt – refresh daily
  ExpiresByType application/xml            "access plus 1 day"
  ExpiresByType text/xml                   "access plus 1 day"
  ExpiresByType text/plain                 "access plus 1 day"

  # JSON-LD sidecar – same TTL as HTML
  ExpiresByType application/ld+json        "access plus 1 hour"
</IfModule>

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options        "SAMEORIGIN"
  Header always set Referrer-Policy        "strict-origin-when-cross-origin"
  Header always set Permissions-Policy     "camera=(), microphone=(), geolocation=()"

  # CDN / Proxy-Caching: statische Assets sind 1 Jahr lang öffentlich cachebar
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|ico|css|js|woff2|woff)$">
    Header merge Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML ist statisch; kurze öffentliche Cache-Dauer für bessere Performance
  <FilesMatch "\.html$">
    Header merge Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# ── Error documents ───────────────────────────────────────────────────────────
ErrorDocument 404 /index.html
